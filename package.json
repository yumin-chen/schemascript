{
	"name": "@artefacto/schemascript",
	"module": "src/main.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"fix": "bun run check",
		"check": "bun x --bun @biomejs/biome check --fix .",
		"format": "bun x --bun @biomejs/biome format --fix .",
		"lint": "bun x --bun @biomejs/biome lint --fix .",
		"start": "bun run src/main.ts"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.5",
		"@types/bun": "^1.3.10",
		"drizzle-kit": "^0.31.9"
	},
	"peerDependencies": {
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"drizzle-orm": "^0.45.1"
	}
}
