{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist",
    "rootDir": "../../",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["../../../src/*"]
    },
    "skipLibCheck": true
  },
  "include": ["index.ts", "core/**/*"]
}
